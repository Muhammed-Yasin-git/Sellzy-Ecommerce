<!-- Products -->
<section>
<div class="container my-5 main-div " style="background-color: #F0EEB3;;">
  <header class="mb-4">
    <h3>New products</h3>
  </header>
  
  <div class="row" style="min-height: max-content;">
    <% for(let i=0; i < 4; i++) { %>
      <div class=" col-sm-3 d-flex"  style="cursor: pointer;">
        <div class="card w-100 my-2" style="box-shadow: 0 10px 36px rgba(0, 0, 0, 0.24);">
            <div style="width: 100%; display: flex; justify-content: end;">
                                

            </div>
            <div style="border: 50px white; width: 100%; display: flex; justify-content: center;" onclick="userdetails('<%=products[i]._id%>')">
              <img src="images/<%=products[i].prd_image[0]%>"
                style=" aspect-ratio: 1 / 1; width: 190px; margin-top:30px;margin-bottom: 15px; height: 210px; object-fit: contain;"
                class="card-img-top" />
            </div>
            <% var shortPname=products[i].pname.slice(0, 25); %>
              <p style="margin-left: 15px; margin-bottom: -18px; opacity: .5;"><%=products[i].category  %></p>
              <div class="card-body d-flex flex-column">
                <h6 class="card-text" style="font-size: 17px;  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin-left: -8px;">
                  <%=shortPname %>
                  <% if(shortPname.length>=22){ %>
                    ..
                    <% } %>
                </h6>

                <p class="card-text" style="margin-left: -8px; opacity: .7; margin-bottom: 6px;">
                </p>
                <h1>
                    <% var discount = products[i].discount %>
                    <% var Odiscount = products[i].price * discount / 100 %>
                    <% var showPrice= products[i].price-Odiscount %>
                
                  <p class="card-text" style="margin-left: -8px; font-weight: bolder; font-size: 20px;">₹<%=Math.floor(showPrice).toLocaleString('en-IN')  %>
                      <span
                        style="font-size: 10px; text-decoration: line-through; font-weight: bolder; opacity: .7;">₹<%=products[i].price.toLocaleString('en-IN') %></span>
                  </p>

                  
                 
                  
                </h1>
                
              </div>
          </div>
   
    </div>
    <% } %>
    <% if(products.length==0){ %>
        <h1>No Products</h1>
        <% } %>
  </div>


  </div>
  
</div>
</section>
<script>

// 

  function userdetails(id){
      const productDetailURL = `/product-details?productId=${id}`;
  
  // Redirect to the user details page.
  window.location.href = productDetailURL;
}

</script>
